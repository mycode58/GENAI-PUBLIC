# %% [markdown]
# Count Vectorize  - generate Vocab from text and create DTM
# 
# 

# %%
import pandas as pd
from sklearn.feature_extraction.text import CountVectorizer


example = ['I love my country which is very diverisy',
           'I like a lot LOT LoT alot',
           'Let me see how it works']


# %%
vect=CountVectorizer()


# %%
vect.fit(example)

# %%
print(vect.get_feature_names_out())

# %%
print(vect.vocabulary_)

# %%
vect.transform(example).toarray()

# %%
pd.DataFrame(vect.transform(example).toarray(), columns=vect.get_feature_names_out())


